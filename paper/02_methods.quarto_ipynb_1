        "    \n",
        "    Z -->|Deep MLP g_m| H1[Hidden L1]\n",
        "    H1 -->|Activation| H2[Hidden L2]\n",
        "    H2 --> R[Recon X'_m]\n",
        "    \n",
        "    style Z fill:#e8f5e9,stroke:#2e7d32,color:#000\n",
        "    style U fill:#fce4ec,stroke:#8e24aa,stroke-width:2px,stroke-dasharray: 5 5,color:#000\n",
