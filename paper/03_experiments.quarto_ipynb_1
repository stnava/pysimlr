        "#| warning: false\n",
        "#| label: tbl-stat-sig-synthetic\n",
        "#| tbl-cap: 'Statistical Significance: Deep vs Linear (Strictly Linear Accuracy, Synthetic). Baseline (Linear) versus Proposed (Deep). Independent Welch''s t-tests [@welch1947generalization] and Cohen''s $d$ [@cohen1988statistical]. Deep architectures yield statistically significant improvements and large effect sizes in complex generative regimes, proving the Deep-to-Linear benefit.'\n",
        "#| echo: false\n",
        "#| output: asis\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from scipy import stats\n",
        "from tabulate import tabulate\n",
        "import os\n",
        "\n",
        "synth_df = pd.read_csv('results_cache/unified_synthetic_v21.csv')\n",
        "\n",
        "def confidence_interval(data, confidence=0.95):\n",
        "    a = 1.0 * np.array(data)\n",
        "    n = len(a)\n",
        "    m, se = np.mean(a), stats.sem(a)\n",
        "    h = se * stats.t.ppf((1 + confidence) / 2., n-1)\n",
        "    return m-h, m+h\n",
        "\n",
        "def cohen_d(x, y):\n",
        "    nx = len(x)\n",
        "    ny = len(y)\n",
        "    dof = nx + ny - 2\n",
